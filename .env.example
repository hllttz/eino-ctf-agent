# =============================================================
# eino-ctf-agent 环境变量配置
# 复制此文件为 .env 并替换占位符为实际值
# =============================================================

# --- LLM 配置 ---
# DeepSeek API Key（必填，用于对话和 Agent 推理）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# DeepSeek API 地址（可选，默认 https://api.deepseek.com）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Embedding 配置 ---
# DashScope API Key（必填，用于文档向量化和检索）
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# DashScope API 地址（可选，默认 https://dashscope.aliyuncs.com/compatible-mode/v1）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Redis 配置 ---
# Redis 密码（可选，本地 Redis Stack 默认无密码时留空）
REDIS_PASSWORD=

# Redis 地址（可选，默认 127.0.0.1:6379，通过 config.yaml 的 redis.addr 覆盖）
# REDIS_ADDR=127.0.0.1:6379

# --- 服务配置 ---
# 配置文件路径（可选，默认 ./configs/config.yaml）
# CONFIG_PATH=./configs/config.yaml

# --- IDA MCP 配置（可选，用于 IDA Pro 二进制分析） ---
# IDA_MCP_URL — IDA MCP endpoint（优先于 IDA_MCP_ENDPOINT）
# IDA_MCP_HOST_HEADER — 覆盖 HTTP Host header（WSL→Windows 场景）
# NO_PROXY — 绕过系统代理
# IDA_MCP_URL=http://172.26.192.1:13338/sse
# IDA_MCP_HOST_HEADER=127.0.0.1:13338
# NO_PROXY=localhost,127.0.0.1,::1,172.26.192.1
# no_proxy=localhost,127.0.0.1,::1,172.26.192.1
